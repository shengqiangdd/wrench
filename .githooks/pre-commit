#!/bin/sh
# Git pre-commit hook for SmartBox
#
# To install:
#   git config core.hooksPath .githooks
#
# Or symlink:
#   ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit

echo "🔍 Running pre-commit checks..."

# Check TypeScript
cd frontend && npx tsc --noEmit 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Aborting."
  cd ..
  exit 1
fi
cd ..

# Check Rust compilation (if cargo available)
if command -v cargo &> /dev/null; then
  cd smartbox-backend && cargo check 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "❌ Rust compilation errors. Aborting."
    cd ..
    exit 1
  fi
  cd ..
fi

echo "✅ All checks passed!"
