# SmartBox Backend Configuration
# Copy this to .env and adjust values

# Server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3001
LOG_LEVEL=info

# CORS (comma-separated origins, empty = permissive)
CORS_ORIGINS=

# Frontend dist path (relative or absolute)
FRONTEND_DIST=./frontend/dist

# Plugins directory
PLUGINS_DIR=./plugins

# JWT Secret (auto-generated if empty)
JWT_SECRET=

# OpenRouter API Key (for AI features)
OPENROUTER_API_KEY=

# Database (optional, falls back to in-memory)
# DATABASE_URL=postgres://user:password@localhost:5432/smartbox
